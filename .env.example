# 12FPS Devvit server storage config (Cloudflare R2 / S3-compatible)
# Copy this file to `.env` and fill in your own values. `.env` is git-ignored by the repo.

# Enable R2/S3 storage (1=on, 0=off)
R2_ENABLED=1

# Bucket name in R2 (must already exist)
R2_BUCKET=12fps-frames

# Jurisdiction-specific R2 S3 endpoint (no trailing slash)
# Example: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# S3 Access Keys (R2 S3 API Tokens with Object Read/Write on the bucket)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: public base URL to redirect image requests (CDN/custom domain)
# If set, /api/frame/:key responds with a 302 redirect to this base
# Example: https://cdn.example.com/frames
R2_PUBLIC_BASE_URL=
