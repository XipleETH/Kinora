{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "kinora-app",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "height": "regular",
        "inline": true
      },
      "app": {
        "entry": "index.html",
        "height": "tall"
      },
      "showcase": {
        "entry": "showcase.html",
        "height": "regular",
        "inline": true
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "media": true
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "Kinora - Collaborative Animation",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Create splash post",
        "description": "Kinora - Join invitation clapperboard",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/splash-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "weekly-animation": {
        "endpoint": "/internal/scheduler/weekly-animation"
      }
    }
  },
  "dev": {
    "subreddit": "kinora_app_dev"
  }
}